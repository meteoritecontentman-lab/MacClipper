{
  "hosting": {
    "public": "website/build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/clipper-for-mac.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/gaming-clipper-for-macbook.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/clipping-software-for-mac.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/how-to-screen-record-on-mac.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/medal-for-mac.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/compare.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/performance.html",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/clipper-for-mac",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/gaming-clipper-for-macbook",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/how-to-clip-on-mac",
        "destination": "/how-to-clip-on-mac.html",
        "type": 301
      },
      {
        "source": "/how-to-screen-record-on-mac",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/clipping-software-for-mac",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/medal-for-mac",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/compare",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      },
      {
        "source": "/performance",
        "destination": "/how-to-clip-on-mac",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5005
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}